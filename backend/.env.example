NEO4J_PASSWORD=secret

# OpenAI
OPENAI_API_KEY=YOUR_OPENAI_API_KEY

# Local paths
DATA_DIR=./data
VIDEOS_DIR=./data/videos
THUMBS_DIR=./data/thumbnails
